# LLM Serving Autoresearch Wiki — Environment Config
# Copy to .env and customize for your setup.

# Model to serve (must be accessible via HuggingFace)
MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# HuggingFace cache directory (models downloaded here persist across restarts)
HF_CACHE=~/.cache/huggingface

# vLLM config
VLLM_MAX_SEQS=128
VLLM_GPU_MEM=0.90
# VLLM_EXTRA_ARGS=--enable-prefix-caching --enable-chunked-prefill

# SGLang config
SGLANG_TP=1
SGLANG_MEM_FRACTION=0.90
# SGLANG_EXTRA_ARGS=--enable-overlap-schedule --enable-dp-attention

# TensorRT-LLM config (only used with `--profile trt-llm`)
# TRT_EXTRA_ARGS=
